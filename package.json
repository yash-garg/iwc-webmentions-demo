{
  "name": "webmentions-worker",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:site": "pnpm --filter site build && wrangler pages deploy site/dist --project-name iwc-webmentions-demo",
    "db:migrate:local": "wrangler d1 migrations apply webmentions --local",
    "db:migrate:remote": "wrangler d1 migrations apply webmentions --remote",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250525.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.92.0"
  }
}
