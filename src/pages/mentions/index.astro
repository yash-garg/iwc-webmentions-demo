---
import Layout from "../../layouts/Layout.astro";

const wmEndpoint = "https://webmentions.rexx.workers.dev";
---

<Layout title="Webmentions">
    <a class="back" href="/">← Home</a>
    <h1>Webmentions</h1>
    <p class="muted" id="status">Loading…</p>
    <ul class="mention-list" id="mention-list"></ul>
    <div id="json-section" style="display:none">
        <p class="json-label">Raw JSON</p>
        <pre class="json-block" id="json-block"></pre>
    </div>
</Layout>

<script define:vars={{ wmEndpoint }}>
    const PROPERTY_LABEL = {
        "like-of": "♥ liked this",
        "repost-of": "↺ reposted this",
        "in-reply-to": "↩ replied",
        "mention-of": "✦ mentioned this",
        "bookmark-of": "⊹ bookmarked this",
    };

    const target = new URLSearchParams(location.search).get("target") ?? "";
    const status = document.getElementById("status");
    const list = document.getElementById("mention-list");
    const jsonSection = document.getElementById("json-section");
    const jsonBlock = document.getElementById("json-block");

    if (!target) {
        status.textContent = "No target specified.";
    } else {
        const apiUrl = `${wmEndpoint}/mentions?target=${encodeURIComponent(target)}`;

        fetch(apiUrl)
                .then((r) => r.json())
                .then((mentions) => {
                    status.textContent = `${mentions.length} mention${mentions.length !== 1 ? "s" : ""} for ${target}`;

                    if (mentions.length === 0) {
                        const p = document.createElement("p");
                        p.textContent = "No webmentions yet.";
                        list.after(p);
                        return;
                    }

                    for (const m of mentions) {
                        const hostname = (() => {
                            try { return new URL(m.source).hostname; } catch { return m.source; }
                        })();
                        const initial = (m.author_name ?? "?").charAt(0).toUpperCase();
                        const label = PROPERTY_LABEL[m.wm_property] ?? m.wm_property ?? "";

                        const li = document.createElement("li");
                        li.className = "mention";

                        const avatar = document.createElement("div");
                        avatar.className = "mention-avatar";
                        avatar.textContent = initial;

                        const body = document.createElement("div");
                        body.className = "mention-body";

                        const header = document.createElement("div");
                        header.className = "mention-header";

                        const authorLink = document.createElement("a");
                        authorLink.className = "mention-author";
                        authorLink.href = m.author_url ?? m.source;
                        authorLink.textContent = m.author_name ?? hostname;

                        const propertySpan = document.createElement("span");
                        propertySpan.className = "mention-property";
                        propertySpan.textContent = label;

                        header.appendChild(authorLink);
                        header.appendChild(propertySpan);
                        body.appendChild(header);

                        if (m.content_text) {
                            const content = document.createElement("p");
                            content.className = "mention-content";
                            content.textContent = m.content_text;
                            body.appendChild(content);
                        }

                        const sourceDiv = document.createElement("div");
                        sourceDiv.className = "mention-source";
                        const sourceLink = document.createElement("a");
                        sourceLink.href = m.source;
                        sourceLink.textContent = m.source;
                        const dot = document.createTextNode(` · ${m.received_at} UTC`);
                        sourceDiv.appendChild(sourceLink);
                        sourceDiv.appendChild(dot);
                        body.appendChild(sourceDiv);

                        li.appendChild(avatar);
                        li.appendChild(body);
                        list.appendChild(li);
                    }

                    jsonSection.style.display = "";
                    jsonBlock.textContent = JSON.stringify(mentions, null, 2);
                })
                .catch((err) => {
                    status.textContent = "Failed to load webmentions.";
                    console.error(err);
                });
    }
</script>
